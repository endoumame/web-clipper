{
  "name": "web-clipper",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "pnpm --filter @web-clipper/api dev",
    "dev:web": "pnpm --filter @web-clipper/web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @web-clipper/api build",
    "build:web": "pnpm --filter @web-clipper/web build",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @web-clipper/api test",
    "test:web": "pnpm --filter @web-clipper/web test",
    "typecheck": "pnpm -r typecheck",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "secretlint": "secretlint \"**/*\"",
    "textlint": "textlint"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.0",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.6.1",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "0.17.4",
    "secretlint": "^11.4.0",
    "textlint": "^15.5.2",
    "textlint-rule-preset-ja-spacing": "^2.4.3",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
